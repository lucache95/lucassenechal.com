# Supabase - Public (safe for client-side)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase - Server only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend - Server only (never expose to client)
RESEND_API_KEY=your-resend-api-key

# Email link security - Server only (never expose to client)
EMAIL_LINK_SECRET=your-email-link-hmac-secret

# Admin dashboard - Server only
ADMIN_SECRET=your-admin-secret-key
